  "devDependencies": {
    "esbuild": "^0.24.0",
    "node-html-parser": "^6.1.13"
  },
  "dependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "benchmark": "^2.1.4",
    "hono": "^4.6.6",
    "nano-jsx": "^0.1.0",
    "preact": "^10.24.3",
    "preact-render-to-string": "^6.5.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
